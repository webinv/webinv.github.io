---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <a href="/" class="shrink-0">
        <img
          src="/images/webinventions-logo-dark.png"
          alt="Web Inventions"
          class="h-8 sm:h-10"
        />
      </a>

      <nav class="hidden md:flex items-center gap-8">
        <a
          href="/"
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath === '/' ? 'text-primary-600' : 'text-gray-600',
          ]}
        >
          Oferta
        </a>
        <a
          href="/realizacje"
          class:list={[
            'text-sm font-medium transition-colors hover:text-primary-600',
            currentPath.startsWith('/realizacje') ? 'text-primary-600' : 'text-gray-600',
          ]}
        >
          Realizacje
        </a>
      </nav>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-gray-600 hover:text-primary-600 transition-colors"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden pb-4">
      <a
        href="/"
        class:list={[
          'block py-2 text-sm font-medium transition-colors hover:text-primary-600',
          currentPath === '/' ? 'text-primary-600' : 'text-gray-600',
        ]}
      >
        Oferta
      </a>
      <a
        href="/realizacje"
        class:list={[
          'block py-2 text-sm font-medium transition-colors hover:text-primary-600',
          currentPath.startsWith('/realizacje') ? 'text-primary-600' : 'text-gray-600',
        ]}
      >
        Realizacje
      </a>
    </nav>
  </div>
</header>

<div class="h-16 sm:h-20"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
